# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/dropos

# ── Authentication ─────────────────────────────────────────────────────────────
JWT_SECRET=your_256_bit_random_string_here
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=$2b$12$YourBcryptHashHere
FRONTEND_DOMAIN=http://localhost:8000

# ── Supabase Storage (image upload) ───────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── AI ─────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Instagram Graph API (v22.0) ────────────────────────────────────────────────
IG_ACCESS_TOKEN=your_ig_access_token_here
IG_ACCOUNT_ID=your_ig_account_id_here

# ── AWS S3 (legacy — replaced by Supabase Storage, keep for reference) ─────────
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_S3_BUCKET=your_s3_bucket_name
# AWS_REGION=us-east-1
